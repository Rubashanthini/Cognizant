<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE hibernate-configuration PUBLIC
        "-//Hibernate/Hibernate Configuration DTD 3.0//EN"
        "http://hibernate.sourceforge.net/hibernate-configuration-3.0.dtd">

<!--
    Hands-on 3: Hibernate Annotation Configuration example.

    Unlike Hands-on 2's hibernate.cfg.xml, this file does NOT reference
    a <mapping resource="..."/> to an .hbm.xml file. Instead, the
    annotated Employee class itself is registered below via
    <mapping class="..."/>, and Hibernate reads the @Entity/@Table/@Id/
    @GeneratedValue/@Column annotations on that class to build the
    mapping metadata.
-->
<hibernate-configuration>
    <session-factory>

        <!-- Connection settings -->
        <property name="hibernate.connection.driver_class">com.mysql.cj.jdbc.Driver</property>
        <property name="hibernate.connection.url">jdbc:mysql://localhost:3306/ormlearn?useSSL=false&amp;serverTimezone=UTC&amp;allowPublicKeyRetrieval=true</property>
        <property name="hibernate.connection.username">root</property>
        <property name="hibernate.connection.password">root</property>

        <property name="hibernate.connection.pool_size">1</property>

        <!-- Dialect -->
        <property name="hibernate.dialect">org.hibernate.dialect.MySQL8Dialect</property>

        <property name="show_sql">true</property>
        <property name="format_sql">true</property>

        <property name="hbm2ddl.auto">update</property>

        <!-- Annotated persistence class (no .hbm.xml file needed) -->
        <mapping class="com.cognizant.ormlearn.hibernateannotation.Employee"/>

    </session-factory>
</hibernate-configuration>
